{
  "manifest_version": 2,
  "version": "1.0.0",
  "name": "好感度插件",
  "description": "基于对话历史和 AI 评分维护用户好感度，并按关系等级影响机器人回复语气。",
  "author": {
    "name": "zerogzy",
    "url": "https://github.com/zerogzy"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/zerogzy/favorability_plugin"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "api.call",
    "llm.generate",
    "message.get_recent",
    "message.get_by_id",
    "send.image",
    "send.text"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "zerogzy.favorability_plugin"
}
